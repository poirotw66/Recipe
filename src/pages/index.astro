---
import BaseLayout from "../layouts/BaseLayout.astro";

const quickIngredients = ["雞蛋", "豆腐", "雞胸肉", "高麗菜", "番茄", "電鍋料理"];
const scenarios = ["一人料理", "租屋料理", "10 分鐘料理", "電鍋料理", "氣炸鍋料理", "減脂料理"];
const recipes = [
  {
    title: "番茄豆腐炒蛋",
    meta: "15 分鐘・1 人份・家常快炒",
    tags: ["雞蛋", "豆腐", "番茄"]
  },
  {
    title: "電鍋雞胸便當菜",
    meta: "20 分鐘・2 份・便當友善",
    tags: ["雞胸肉", "電鍋", "高蛋白"]
  },
  {
    title: "高麗菜菇菇拌麵",
    meta: "12 分鐘・1 人份・冰箱清菜",
    tags: ["高麗菜", "菇類", "麵條"]
  }
];
const popularIngredients = ["雞蛋", "豆腐", "雞胸肉", "高麗菜", "洋蔥", "青蔥", "馬鈴薯", "白飯"];
---

<BaseLayout
  title="今天煮什麼"
  description="用冰箱現有食材，快速找到今晚能煮的簡單料理，從雞蛋、豆腐、高麗菜一路找到適合的一人份家常菜。"
  canonicalPath="/"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">冰箱裡有什麼，就從那裡開始</p>
      <h1 class="page-title">用手邊食材，找今天能煮的簡單料理</h1>
      <p class="page-copy">
        首頁先幫你從冰箱剩料出發，不用先想菜名。輸入 1-3 樣你現在有的食材，就能前往工具頁看適合的料理方向。
      </p>

      <div class="search-panel">
        <form class="search-form" data-home-search>
          <label class="field">
            <span class="eyebrow">輸入手邊食材</span>
            <input
              name="ingredients"
              type="search"
              placeholder="雞蛋、豆腐、高麗菜"
              autocomplete="off"
            />
          </label>
          <button class="button primary" type="submit">找今天能煮的料理</button>
        </form>
        <p class="form-error" data-home-search-error hidden>先輸入 1-3 樣你手邊有的食材。</p>

        <div class="chip-row" aria-label="熱門快速食材">
          {quickIngredients.map((item) => (
            <a class="chip note" href={`/tools/fridge-recipe?ingredients=${encodeURIComponent(item)}`}>{item}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">情境入口</p>
      <h2>先從你今天的烹飪情境挑起</h2>
      <div class="grid">
        {scenarios.map((scenario) => (
          <a class="note-card card-body" href="/scenarios">
            <h3>{scenario}</h3>
            <p>保留情境列表入口，後續會接上對應的食譜群組與長尾 SEO 頁。</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">熱門食譜</p>
      <h2>先看看現在最適合延伸成內容的料理方向</h2>
      <div class="grid">
        {recipes.map((recipe) => (
          <article class="card recipe-card">
            <div class="recipe-image" aria-hidden="true"></div>
            <div class="card-body">
              <h3>{recipe.title}</h3>
              <p>{recipe.meta}</p>
              <div class="chip-row">
                {recipe.tags.map((tag) => <span class="chip">{tag}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
      <p class="section-action"><a class="button" href="/recipes">看全部食譜</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">熱門食材</p>
      <h2>從常見食材切進去，也能很快開始找菜</h2>
      <div class="chip-row" aria-label="熱門食材入口">
        {popularIngredients.map((ingredient) => (
          <a class="chip note" href="/ingredients">{ingredient}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card tool-promo">
        <div class="card-body">
          <p class="eyebrow">冰箱剩料工具</p>
          <h2>不想先想菜名時，直接用冰箱現況找方向</h2>
          <p>
            工具頁已先完成輸入面與 placeholder 結果流程，下一階段會接上本地 JSON 比對，依命中食材與缺少食材數量排序。
          </p>
          <a class="button note" href="/tools/fridge-recipe">用冰箱剩料找食譜</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<script is:inline src="/scripts/home-search.js"></script>
