---
import { getCollection } from "astro:content";
import RecipeCard from "../components/RecipeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { brandDisplayName } from "../lib/site";
import { getFeaturedRecipes, getLatestRecipes } from "../lib/recipes";
import { ingredientItems, scenarioItems } from "../lib/taxonomy";

const quickIngredients = ingredientItems.slice(0, 6).map((item) => item.name);
const featuredScenarios = scenarioItems.slice(0, 6);
const popularIngredients = ingredientItems.slice(0, 8);

const allRecipes = await getCollection("recipes");
const featuredRecipes = getFeaturedRecipes(allRecipes, 3);
const popularRecipes = featuredRecipes.length > 0 ? featuredRecipes : getLatestRecipes(allRecipes, 3);
---

<BaseLayout
  title={brandDisplayName}
  description={`${brandDisplayName} 用冰箱現有食材，快速找到今晚能煮的簡單料理，從雞蛋、豆腐、高麗菜一路找到適合的一人份家常菜。`}
  canonicalPath="/"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">今晚煮什麼</p>
      <h1 class="page-title">先看冰箱，再決定晚餐</h1>
      <p class="page-copy">
        輸入 1 到 3 樣現有食材，直接跳到冰箱剩料工具看推薦結果。
      </p>

      <div class="search-panel">
        <form class="search-form" data-home-search>
          <label class="field">
            <span class="eyebrow">輸入你有的食材</span>
            <input
              name="ingredients"
              type="search"
              placeholder="雞蛋、豆腐、高麗菜"
              autocomplete="off"
              data-home-search-input
            />
          </label>
          <button class="button primary" type="submit">找今天能煮的料理</button>
        </form>
        <p class="form-error" data-home-search-error hidden></p>

        <div class="chip-row" aria-label="快速食材入口">
          {quickIngredients.map((item) => (
            <a class="chip note" href={`/tools/fridge-recipe?ingredients=${encodeURIComponent(item)}#fridge-results`}>{item}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">料理情境</p>
      <h2>依今晚狀況挑方向</h2>
      <div class="grid">
        {featuredScenarios.map((scenario) => (
          <a class="note-card card-body" href={`/scenarios/${scenario.slug}/`}>
            <h3>{scenario.name}</h3>
            <p>{scenario.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">精選食譜</p>
      <h2>小廚房也能快速開飯</h2>
      <div class="grid">
        {popularRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
      </div>
      <p class="section-action"><a class="button" href="/recipes">看全部食譜</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">主題專區</p>
      <h2>想吃早午餐、牛肉或義大利麵，從這裡進</h2>
      <div class="grid topic-hub-grid">
        <a class="note-card card-body" href="/brunch/">
          <h3>早午餐專區</h3>
          <p>牛排、海鮮、雞肉與蛋奶素主盤，週末在家也能吃出餐廳感。</p>
        </a>
        <a class="note-card card-body" href="/beef/">
          <h3>牛肉專區</h3>
          <p>炒飯、快炒、湯品與蓋飯，一人份晚餐與便當都適合。</p>
        </a>
        <a class="note-card card-body" href="/pasta/">
          <h3>義大利麵專區</h3>
          <p>青醬、蒜香、番茄與白醬麵，從雞肉到海鮮一次找齊。</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">常用食材</p>
      <h2>從常備食材找做法</h2>
      <div class="chip-row" aria-label="熱門食材入口">
        {popularIngredients.map((ingredient) => (
          <a class="chip note" href={`/ingredients/${ingredient.slug}/`}>{ingredient.name}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
<script is:inline src="/scripts/home-search.js"></script>
