---
import { getCollection } from "astro:content";
import RecipeCard from "../components/RecipeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeaturedRecipes, getLatestRecipes } from "../lib/recipes";
import { ingredientItems, scenarioItems } from "../lib/taxonomy";

const quickIngredients = ingredientItems.slice(0, 6).map((item) => item.name);
const featuredScenarios = scenarioItems.slice(0, 6);
const popularIngredients = ingredientItems.slice(0, 8);

const allRecipes = await getCollection("recipes");
const featuredRecipes = getFeaturedRecipes(allRecipes, 3);
const popularRecipes = featuredRecipes.length > 0 ? featuredRecipes : getLatestRecipes(allRecipes, 3);
---

<BaseLayout
  title="今天煮什麼"
  description="用冰箱現有食材，快速找到今晚能煮的簡單料理，從雞蛋、豆腐、高麗菜一路找到適合的一人份家常菜。"
  canonicalPath="/"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">冰箱裡有什麼，就從那裡開始</p>
      <h1 class="page-title">今天晚餐不用先想菜名，先看你手邊有什麼</h1>
      <p class="page-copy">
        首頁先幫你從冰箱剩料出發，不用先想菜名。輸入 1 到 3 樣你現在有的食材，就能前往工具頁看最接近能煮的料理。
      </p>

      <div class="search-panel">
        <form class="search-form" data-home-search>
          <label class="field">
            <span class="eyebrow">輸入你有的食材</span>
            <input
              name="ingredients"
              type="search"
              placeholder="雞蛋、豆腐、高麗菜"
              autocomplete="off"
            />
          </label>
          <button class="button primary" type="submit">找今天能煮的料理</button>
        </form>
        <p class="form-error" data-home-search-error hidden>請先輸入 1 到 3 樣食材。</p>

        <div class="chip-row" aria-label="快速食材入口">
          {quickIngredients.map((item) => (
            <a class="chip note" href={`/tools/fridge-recipe?ingredients=${encodeURIComponent(item)}`}>{item}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">料理情境入口</p>
      <h2>先從你今天的做飯情境開始找方向</h2>
      <div class="grid">
        {featuredScenarios.map((scenario) => (
          <a class="note-card card-body" href={`/scenarios/${scenario.slug}/`}>
            <h3>{scenario.name}</h3>
            <p>{scenario.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">牛肉專區</p>
      <h2>14 道牛肉料理，炒飯、快炒、湯品一次找齊</h2>
      <p class="page-copy">
        從蔥花牛肉炒飯、洋蔥牛肉蓋飯到蒜香牛肉片與番茄牛肉麵，適合一人份晚餐與便當準備。
      </p>
      <p class="section-action"><a class="button note" href="/beef">進入牛肉專區</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">義大利麵專區</p>
      <h2>今晚想吃麵，青醬肉類海鮮與家常醬汁一次找齊</h2>
      <p class="page-copy">
        專區含青醬雞肉、青醬鮭魚與蝦仁等做法，也有蒜香、番茄、白醬麵，並可從義大利麵食材頁看保存方式。
      </p>
      <p class="section-action"><a class="button note" href="/pasta">進入義大利麵專區</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">熱門食譜</p>
      <h2>先看最近適合小廚房的一批家常料理</h2>
      <div class="grid">
        {popularRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
      </div>
      <p class="section-action"><a class="button" href="/recipes">看全部食譜</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">熱門食材</p>
      <h2>從常備食材直接展開，找保存方式與相關做法</h2>
      <div class="chip-row" aria-label="熱門食材入口">
        {popularIngredients.map((ingredient) => (
          <a class="chip note" href={`/ingredients/${ingredient.slug}/`}>{ingredient.name}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card tool-promo">
        <div class="card-body">
          <p class="eyebrow">冰箱剩料工具</p>
          <h2>不想先想菜名時，直接用冰箱現況找方向</h2>
          <p>
            工具頁現在已接上本地 recipe 與 taxonomy 資料，會依命中食材、缺少食材與偏好條件排序，
            幫你快速縮小今天晚餐的選擇。
          </p>
          <a class="button note" href="/tools/fridge-recipe">用冰箱剩料找食譜</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
<script is:inline src="/scripts/home-search.js"></script>
