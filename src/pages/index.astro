---
import { getCollection } from "astro:content";
import RecipeCard from "../components/RecipeCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { brandDisplayName } from "../lib/site";
import { getFeaturedRecipes, getLatestRecipes } from "../lib/recipes";
import { getPopularIngredients, scenarioItems } from "../lib/taxonomy";

const allRecipes = await getCollection("recipes");
const quickIngredients = getPopularIngredients(allRecipes, 6).map((item) => item.name);
const featuredScenarios = scenarioItems.slice(0, 6);
const popularIngredients = getPopularIngredients(allRecipes, 8);

const topicHubCards = [
  {
    href: "/quick-meals/",
    label: "Quick",
    title: "10 分鐘專區",
    description: "忙碌平日晚餐與宵夜，從炒飯、拌麵到快手主菜快速開飯。",
    cover: "/images/recipes/quick-kimchi-fried-rice.webp"
  },
  {
    href: "/air-fryer/",
    label: "Air Fryer",
    title: "氣炸鍋專區",
    description: "少顧鍋的一人份主菜，雞肉、海鮮與蔬菜都能快速完成。",
    cover: "/images/recipes/air-fryer-salmon-broccoli.webp"
  },
  {
    href: "/brunch/",
    label: "Brunch",
    title: "早午餐專區",
    description: "牛排、海鮮、雞肉與蛋奶素主盤，週末在家也能吃出餐廳感。",
    cover: "/images/recipes/surf-turf-brunch.webp"
  },
  {
    href: "/beef/",
    label: "Beef",
    title: "牛肉專區",
    description: "炒飯、快炒、湯品與蓋飯，一人份晚餐與便當都適合。",
    cover: "/images/recipes/scallion-beef-fried-rice.webp"
  },
  {
    href: "/pasta/",
    label: "Pasta",
    title: "義大利麵專區",
    description: "青醬、蒜香、番茄與白醬麵，從雞肉到海鮮一次找齊。",
    cover: "/images/recipes/garlic-cream-shrimp-pasta.webp"
  }
];

const featuredRecipes = getFeaturedRecipes(allRecipes, 3);
const popularRecipes = featuredRecipes.length > 0 ? featuredRecipes : getLatestRecipes(allRecipes, 3);
---

<BaseLayout
  title={brandDisplayName}
  description={`${brandDisplayName} 用冰箱現有食材，快速找到今晚能煮的簡單料理，從雞蛋、豆腐、高麗菜一路找到適合的一人份家常菜。`}
  canonicalPath="/"
>
  <section class="hero">
    <div class="container">
      <div class="hero-intro">
        <p class="eyebrow">今晚煮什麼</p>
        <h1 class="page-title">先看冰箱，再決定晚餐</h1>
        <p class="page-copy">輸入 1 到 3 樣現有食材，為你挑選今晚適合的簡單料理。</p>
      </div>

      <div class="search-panel">
        <form class="search-form" data-home-search>
          <label class="field">
            <span class="eyebrow">輸入你有的食材</span>
            <input
              name="ingredients"
              type="search"
              placeholder="雞蛋、豆腐、高麗菜"
              autocomplete="off"
              data-home-search-input
            />
          </label>
          <button class="button primary" type="submit">找今天能煮的料理</button>
        </form>
        <p class="form-error" data-home-search-error hidden></p>

        <div class="chip-row" aria-label="快速食材入口">
          {quickIngredients.map((item) => (
            <a class="chip note" href={`/tools/fridge-recipe?ingredients=${encodeURIComponent(item)}#fridge-results`}>{item}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">料理情境</p>
        <h2>依今晚狀況挑方向</h2>
      </div>
      <div class="grid">
        {featuredScenarios.map((scenario) => (
          <a class="note-card card-body" href={`/scenarios/${scenario.slug}/`}>
            <h3>{scenario.name}</h3>
            <p>{scenario.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">精選食譜</p>
        <h2>今晚，從這幾道開始</h2>
      </div>
      <div class="grid">
        {popularRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
      </div>
      <p class="section-action"><a class="button" href="/recipes">看全部食譜</a></p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">主題專區</p>
        <h2>依心情，走進不同的小廚房角落</h2>
      </div>
      <div class="grid topic-hub-grid">
        {topicHubCards.map((card) => (
          <a class="topic-card" href={card.href}>
            <span class="topic-card__label">{card.label}</span>
            <div
              class="topic-card__media"
              style={`background-image: url('${card.cover}')`}
              role="img"
              aria-label={`${card.title}預覽`}
            />
            <div class="topic-card__body">
              <h3>{card.title}</h3>
              <p>{card.description}</p>
              <span class="topic-card__cta">進入專區 →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">常用食材</p>
        <h2>從常備食材找做法</h2>
      </div>
      <div class="chip-row" aria-label="熱門食材入口">
        {popularIngredients.map((ingredient) => (
          <a class="chip note" href={`/ingredients/${ingredient.slug}/`}>{ingredient.name}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
<script is:inline src="/scripts/home-search.js"></script>
