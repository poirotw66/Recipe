---
import ContactArticle from "../components/ContactArticle.astro";
import StaticArticleLayout from "../layouts/StaticArticleLayout.astro";
import { brandName, brandTagline, legalLastUpdated } from "../lib/site";
import { getContactPage } from "../i18n/contact-page";

const content = getContactPage("zh-TW");
---

<StaticArticleLayout
  title={content.title}
  description={`透過 email 聯絡 ${brandName}（${brandTagline}），回報內容問題、合作需求或站務建議。`}
  canonicalPath="/contact"
  eyebrow={content.eyebrow}
  updatedAt={legalLastUpdated}
>
  <ContactArticle locale="zh-TW" />
</StaticArticleLayout>
