---
import AboutBrandMark from "../components/AboutBrandMark.astro";
import StaticArticleLayout from "../layouts/StaticArticleLayout.astro";
import {
  bloss0mBrandName,
  bloss0mSiteUrl,
  bloomPickerUrl,
  bloomRenderUrl,
  brandName,
  brandTagline,
  contactEmail,
  legalLastUpdated,
  recipeSiteUrl
} from "../lib/site";
---

<StaticArticleLayout
  title="關於本站"
  description={`${brandName}（${brandTagline}）專注整理台灣一人份、租屋族與想快速開飯的家常料理靈感。`}
  canonicalPath="/about"
  eyebrow="About"
  updatedAt={legalLastUpdated}
>
  <AboutBrandMark alt={`${brandName}（${brandTagline}）品牌插畫`} />

  <section>
    <h2>本站在做什麼</h2>
    <p>
      {brandName}（{brandTagline}）是一個以靜態內容為主的食譜 SEO 站，整理適合台灣家庭廚房、小套房廚具與忙碌生活節奏的家常料理。
      我們希望讓讀者在 10 到 30 分鐘內，快速找到今天能煮、冰箱裡也可能有材料的做法。
    </p>
  </section>

  <section>
    <h2>適合哪些人</h2>
    <ul class="article-list">
      <li>一人份、兩人份的小家庭日常料理需求。</li>
      <li>租屋族、學生、上班族想降低備料與清理負擔。</li>
      <li>想用常見台灣食材快速完成家常菜的人。</li>
    </ul>
  </section>

  <section>
    <h2>內容原則</h2>
    <ul class="article-list">
      <li>優先提供容易掃讀的步驟、時間、份量與替代建議。</li>
      <li>營養、保存與食材搭配資訊屬整理與估算用途，不構成醫療建議。</li>
      <li>站點以 Markdown 與 JSON 靜態內容建置，會持續擴充與修正。</li>
    </ul>
  </section>

  <section>
    <h2>與 Bloss0m 的關係</h2>
    <p>
      {brandName} 是
      <a href={bloss0mSiteUrl} rel="noopener noreferrer">{bloss0mBrandName}</a>
      生態中的食譜站，中文口號為「{brandTagline}」，網址為
      <a href={recipeSiteUrl}>{recipeSiteUrl}</a>。
      同系列產品還包含
      <a href={bloomPickerUrl} rel="noopener noreferrer">Bloom Picker</a>
      （色票推薦）與
      <a href={bloomRenderUrl} rel="noopener noreferrer">Bloom Render</a>
      （繪圖入口）。
    </p>
    <p>
      Bloss0m 是我個人網路內容與實驗專案的集合入口；這裡專注在台灣家常、一人份與租屋族能實際開做的食譜整理，與主站其他主題分開，方便你專心找今晚要煮什麼。
    </p>
  </section>

  <section>
    <h2>聯絡方式</h2>
    <p>
      如果你想回報內容錯誤、提出合作需求或補充建議，可以寄信到
      <a href={`mailto:${contactEmail}`}>{contactEmail}</a>，或直接前往 <a href="/contact">聯絡我們</a>。
    </p>
  </section>
</StaticArticleLayout>
