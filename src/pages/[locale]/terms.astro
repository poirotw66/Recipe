---
import TermsArticle from "../../components/TermsArticle.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { legalLastUpdated } from "../../lib/site";
import { localePath, t } from "../../lib/i18n";
import { getTermsPage } from "../../i18n/terms-page";
import { localeStaticPaths, requireNonDefaultLocale } from "../../lib/i18n-routes";

export function getStaticPaths() {
  return localeStaticPaths();
}

const locale = requireNonDefaultLocale(Astro.params.locale);
const content = getTermsPage(locale);
const canonical = localePath(locale, "/terms");
---

<BaseLayout
  title={content.title}
  description={content.description}
  canonicalPath={canonical}
  alternatePath="/terms"
  locale={locale}
>
  <article class="article article-shell">
    <Breadcrumb
      items={[
        { name: t(locale, "nav.home"), href: localePath(locale, "/") },
        { name: content.title }
      ]}
    />
    <p class="eyebrow">{content.eyebrow}</p>
    <h1 class="page-title">{content.title}</h1>
    <p class="page-copy">{content.description}</p>
    <p class="caption">
      {content.updatedLabel}: {legalLastUpdated}
    </p>
    <div class="article-sections">
      <TermsArticle locale={locale} />
    </div>
  </article>
</BaseLayout>
