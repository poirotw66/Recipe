---
import LocalizedTopicHubPage from "../../../components/LocalizedTopicHubPage.astro";
import { localeStaticPaths, requireNonDefaultLocale } from "../../../lib/i18n-routes";

export function getStaticPaths() {
  return localeStaticPaths();
}

const locale = requireNonDefaultLocale(Astro.params.locale);
---

<LocalizedTopicHubPage hubSlug="pasta" locale={locale} label="Pasta" heroCover="/images/recipes/garlic-cream-shrimp-pasta.webp" />
