---
import JsonLd from "../../../components/JsonLd.astro";
import RecipeCard from "../../../components/RecipeCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { localePath, t } from "../../../lib/i18n";
import { localeStaticPaths, requireNonDefaultLocale } from "../../../lib/i18n-routes";
import { listRecipesForLocale } from "../../../lib/recipe-locale";
import { sortRecipesByPublishedDate } from "../../../lib/recipes";
import { buildBreadcrumbJsonLd, buildItemListJsonLd, buildThingJsonLd } from "../../../lib/seo";
import {
  getIngredientBySlug,
  getIngredientLabel,
  getRecipesByScenario,
  getScenarioBySlug,
  getScenarioLabel,
  scenarioItems
} from "../../../lib/taxonomy";

export async function getStaticPaths() {
  const paths: Array<{ params: { locale: string; slug: string } }> = [];
  for (const { params } of localeStaticPaths()) {
    for (const scenario of scenarioItems) {
      paths.push({ params: { locale: params.locale, slug: scenario.slug } });
    }
  }
  return paths;
}

const locale = requireNonDefaultLocale(Astro.params.locale);
const slug = Astro.params.slug;

if (!slug) {
  throw new Error("Scenario slug is required.");
}

const scenario = getScenarioBySlug(slug);

if (!scenario) {
  return Astro.redirect("/404");
}

const recipes = sortRecipesByPublishedDate(await listRecipesForLocale(locale));
const allRelatedRecipes = getRecipesByScenario(recipes, scenario.slug, locale);
const relatedRecipePreviewLimit = 12;
const popularRecipes = [...allRelatedRecipes]
  .sort(
    (left, right) =>
      Number(right.data.featured) - Number(left.data.featured) ||
      right.data.publishedAt.getTime() - left.data.publishedAt.getTime()
  )
  .slice(0, 6);
const relatedRecipes = allRelatedRecipes.slice(0, relatedRecipePreviewLimit);
const hasMoreRelatedRecipes = allRelatedRecipes.length > relatedRecipePreviewLimit;
const scenarioName = getScenarioLabel(scenario, locale);
const canonical = localePath(locale, `/scenarios/${scenario.slug}`);
const commonIngredients = scenario.commonIngredients
  .map((ingredientSlug) => getIngredientBySlug(ingredientSlug))
  .filter((ingredient): ingredient is NonNullable<typeof ingredient> => Boolean(ingredient));
const relatedScenarios = scenario.relatedScenarios
  .map((scenarioSlug) => getScenarioBySlug(scenarioSlug))
  .filter((relatedScenario): relatedScenario is NonNullable<typeof relatedScenario> => Boolean(relatedScenario));
const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: t(locale, "nav.home"), path: localePath(locale, "/") },
  { name: t(locale, "nav.scenarios"), path: localePath(locale, "/scenarios") },
  { name: scenarioName, path: canonical }
]);
const scenarioJsonLd = buildThingJsonLd(scenario, canonical);
const relatedRecipeListJsonLd =
  relatedRecipes.length > 0
    ? buildItemListJsonLd(
        `${scenarioName} recipes`,
        canonical,
        relatedRecipes.map((recipe) => ({
          name: recipe.data.title,
          path: localePath(locale, `/recipes/${recipe.slug}`)
        }))
      )
    : null;
---

<BaseLayout
  title={scenario.seoTitle}
  description={scenario.seoDescription}
  canonicalPath={canonical}
  alternatePath={`/scenarios/${scenario.slug}`}
  locale={locale}
>
  <JsonLd data={breadcrumbJsonLd} />
  <JsonLd data={scenarioJsonLd} />
  {relatedRecipeListJsonLd && <JsonLd data={relatedRecipeListJsonLd} />}
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={localePath(locale, "/")}>{t(locale, "nav.home")}</a>
        <span>/</span>
        <a href={localePath(locale, "/scenarios")}>{t(locale, "nav.scenarios")}</a>
        <span>/</span>
        <span>{scenarioName}</span>
      </nav>

      <section class="recipe-hero">
        <div>
          <p class="eyebrow">{t(locale, "taxonomy.scenarioEyebrow")}</p>
          <h1 class="page-title">{scenarioName}</h1>
          <p class="page-copy">{scenario.description}</p>
          <div class="chip-row">
            {scenario.tags.map((tag) => <span class="chip note">{tag}</span>)}
          </div>
        </div>
        <div class="card card-body taxonomy-summary">
          <p class="eyebrow">{t(locale, "taxonomy.scenarioSummaryEyebrow")}</p>
          <p>{scenario.seoDescription}</p>
        </div>
      </section>

      {popularRecipes.length > 0 && (
        <section class="section section-compact">
          <p class="eyebrow">{t(locale, "taxonomy.popularEyebrow")}</p>
          <h2>{t(locale, "taxonomy.popularTitle")}</h2>
          <div class="grid">
            {popularRecipes.map((recipe) => <RecipeCard recipe={recipe} locale={locale} />)}
          </div>
        </section>
      )}

      <section class="section section-compact">
        <p class="eyebrow">{t(locale, "taxonomy.relatedEyebrow")}</p>
        <div class="grid">
          {relatedRecipes.map((recipe) => <RecipeCard recipe={recipe} locale={locale} />)}
        </div>
        {hasMoreRelatedRecipes && (
          <div class="section-links">
            <a class="button note" href={localePath(locale, "/recipes")}>
              {t(locale, "taxonomy.moreRecipes")}
            </a>
          </div>
        )}
      </section>

      <section class="section section-compact">
        <div class="recipe-content-grid">
          <article class="card">
            <div class="card-body">
              <p class="eyebrow">{t(locale, "taxonomy.commonIngredients")}</p>
              <div class="chip-row">
                {commonIngredients.map((ingredient) => (
                  <a class="chip note" href={localePath(locale, `/ingredients/${ingredient.slug}`)}>
                    {getIngredientLabel(ingredient, locale)}
                  </a>
                ))}
              </div>
            </div>
          </article>

          <article class="card">
            <div class="card-body">
              <p class="eyebrow">{t(locale, "taxonomy.relatedScenarios")}</p>
              <div class="chip-row">
                {relatedScenarios.map((item) => (
                  <a class="chip" href={localePath(locale, `/scenarios/${item.slug}`)}>
                    {getScenarioLabel(item, locale)}
                  </a>
                ))}
              </div>
            </div>
          </article>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
