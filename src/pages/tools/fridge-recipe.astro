---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ingredientItems } from "../../lib/taxonomy";
import { preferenceDefinitions } from "../../lib/fridge.js";

const quickIngredients = ["雞蛋", "豆腐", "番茄", "雞胸肉", "蘑菇"];
const recipes = (await getCollection("recipes")).map((recipe) => ({
  slug: recipe.slug,
  title: recipe.data.title,
  description: recipe.data.description,
  totalTime: recipe.data.totalTime,
  protein: recipe.data.protein ?? 0,
  difficulty: recipe.data.difficulty,
  equipment: recipe.data.equipment,
  scenarios: recipe.data.scenarios,
  ingredients: recipe.data.ingredients.map((item) => item.name)
}));

const toolData = {
  ingredients: ingredientItems,
  recipes,
  preferences: preferenceDefinitions.map(({ key, label }) => ({ key, label }))
};
---

<BaseLayout
  title="冰箱剩料工具"
  description="輸入你手邊有的食材，用本地 recipe 與 taxonomy 資料找出今天最接近能煮的料理。"
  canonicalPath="/tools/fridge-recipe"
>
  <section class="section">
    <div class="container tool-layout">
      <div>
        <p class="eyebrow">Fridge Recipe Tool</p>
        <h1 class="page-title">冰箱剩料工具</h1>
        <p class="page-copy">
          輸入你冰箱裡現有的食材，工具會依命中食材數、缺少食材數與偏好條件，幫你排序目前最接近能煮的料理。
        </p>

        <form class="search-panel" data-fridge-form>
          <label class="field">
            <span class="eyebrow">輸入你手邊的食材</span>
            <textarea
              class="tool-input"
              name="ingredients"
              placeholder="雞蛋、豆腐、高麗菜"
              data-fridge-input
            ></textarea>
          </label>
          <p class="form-error" data-fridge-error hidden>先輸入至少 1 樣食材。</p>

          <div class="filter-group">
            <p class="filter-label">偏好條件</p>
            <div class="chip-row" data-preference-group>
              {preferenceDefinitions.map((item) => (
                <button class="chip" type="button" data-preference={item.key} aria-pressed="false">{item.label}</button>
              ))}
            </div>
          </div>

          <div class="filter-group">
            <p class="filter-label">快速加入食材</p>
            <div class="chip-row">
              {quickIngredients.map((item) => (
                <button class="chip note" type="button" data-quick-ingredient={item}>{item}</button>
              ))}
            </div>
          </div>

          <div class="section-links">
            <button class="button primary" type="submit">找能煮的料理</button>
            <button class="button" type="button" data-fridge-clear hidden>清空</button>
          </div>
        </form>
      </div>

      <div class="results-column">
        <section class="card empty-panel" data-fridge-empty>
          <div class="card-body">
            <p class="eyebrow">開始比對</p>
            <h2>先把冰箱裡有的東西列出來</h2>
            <p>送出後會依命中食材、缺少食材和偏好條件顯示最接近的料理，並補上還差哪些材料。</p>
          </div>
        </section>

        <section class="card empty-panel" data-fridge-no-results hidden>
          <div class="card-body">
            <p class="eyebrow">沒有直接命中</p>
            <h2>目前沒有對上的食譜</h2>
            <p data-no-result-copy>試著換成更常見的食材名稱，或回食材索引找相近材料。</p>
          </div>
        </section>

        <section class="section section-compact" data-fridge-results hidden>
          <p class="eyebrow">推薦結果</p>
          <div class="card result-summary">
            <div class="card-body">
              <h2>目前最接近能煮的料理</h2>
              <p data-result-summary-copy>工具會在這裡整理你已命中的食材與偏好。</p>
            </div>
          </div>
          <div class="grid" data-result-grid></div>
        </section>

        <section class="section section-compact">
          <p class="eyebrow">延伸入口</p>
          <div class="chip-row">
            <a class="chip note" href="/recipes">看全部食譜</a>
            <a class="chip note" href="/ingredients">從食材索引找靈感</a>
            <a class="chip note" href="/scenarios">從情境列表找方向</a>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
<script is:inline id="fridge-tool-data" type="application/json" set:html={JSON.stringify(toolData)}></script>
<script is:inline src="/scripts/fridge-tool.js"></script>
