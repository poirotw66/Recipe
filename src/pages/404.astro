---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import { brandName, brandTagline } from "../lib/site";
---

<BaseLayout
  title="找不到頁面"
  description={`${brandName}（${brandTagline}）找不到你要求的頁面，請從首頁或食譜列表重新開始。`}
  canonicalPath="/404"
>
  <section class="article article-shell">
    <Breadcrumb items={[{ name: "首頁", href: "/" }, { name: "找不到頁面" }]} />
    <p class="eyebrow">404</p>
    <h1 class="page-title">找不到這個頁面</h1>
    <p class="page-copy">
      連結可能已變更，或這道料理還沒寫進食譜庫。你可以從下面幾個入口繼續找今晚要煮什麼。
    </p>
    <div class="chip-row">
      <a class="button primary" href="/">回到首頁</a>
      <a class="button note" href="/recipes/">瀏覽食譜</a>
      <a class="button note" href="/tools/fridge-recipe/">冰箱剩料工具</a>
    </div>
  </section>
</BaseLayout>
