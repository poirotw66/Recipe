---
import { getCollection } from "astro:content";
import JsonLd from "../../components/JsonLd.astro";
import RecipeCard from "../../components/RecipeCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildCollectionPageJsonLd } from "../../lib/seo";
import { sortRecipesByPublishedDate } from "../../lib/recipes";

const categories = ["全部", "家常菜", "便當菜", "早餐", "湯品"];
const times = ["全部", "10 分鐘", "15 分鐘", "30 分鐘內"];
const tools = ["全部", "電鍋", "氣炸鍋", "微波爐", "平底鍋"];

const recipes = sortRecipesByPublishedDate(await getCollection("recipes"));
const collectionJsonLd = buildCollectionPageJsonLd(
  "食譜列表",
  "整理適合一人份、租屋族與台灣常見食材的簡單食譜。",
  "/recipes/"
);
---

<BaseLayout
  title="食譜列表"
  description="整理適合一人份、租屋族與台灣常見食材的簡單食譜，改由 Markdown content collection 驅動。"
  canonicalPath="/recipes"
>
  <JsonLd data={collectionJsonLd} />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Recipes</p>
      <h1 class="page-title">食譜列表</h1>
      <p class="page-copy">
        這一頁已接上 recipe content collection。第一版先提供真實食譜卡與靜態篩選入口，後續再補更完整的篩選互動。
      </p>

      <div class="search-panel">
        <label class="field">
          <span class="eyebrow">關鍵字</span>
          <input type="search" name="keyword" placeholder="搜尋食譜名稱或食材，例如 雞蛋" />
        </label>
        <div class="filter-group">
          <p class="filter-label">分類</p>
          <div class="filter-bar">
            {categories.map((filter) => <button class="chip" type="button">{filter}</button>)}
          </div>
        </div>
        <div class="filter-group">
          <p class="filter-label">時間</p>
          <div class="filter-bar">
            {times.map((filter) => <button class="chip" type="button">{filter}</button>)}
          </div>
        </div>
        <div class="filter-group">
          <p class="filter-label">設備</p>
          <div class="filter-bar">
            {tools.map((filter) => <button class="chip" type="button">{filter}</button>)}
          </div>
        </div>
      </div>

      <div class="grid">
        {recipes.map((recipe) => <RecipeCard recipe={recipe} />)}
      </div>

      <div class="section-links">
        <a class="button" href="/ingredients">先看熱門食材</a>
        <a class="button note" href="/scenarios">改從料理情境找</a>
      </div>
    </div>
  </section>
</BaseLayout>
