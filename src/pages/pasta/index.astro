---
import { getCollection } from "astro:content";
import JsonLd from "../../components/JsonLd.astro";
import RecipeCard from "../../components/RecipeCard.astro";
import TopicHubIntro from "../../components/TopicHubIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortRecipesByPublishedDate } from "../../lib/recipes";
import { buildBreadcrumbJsonLd, buildCollectionPageJsonLd, buildThingJsonLd } from "../../lib/seo";
import {
  filterIngredientsWithRecipes,
  getIngredientBySlug,
  getRecipesByTopicHub,
  getScenarioBySlug,
  getTopicHubBySlug
} from "../../lib/taxonomy";

const hub = getTopicHubBySlug("pasta");

if (!hub) {
  throw new Error("Pasta topic hub is not configured.");
}

const recipes = sortRecipesByPublishedDate(await getCollection("recipes"));
const pastaRecipes = getRecipesByTopicHub(recipes, hub.slug);
const pestoRecipes = pastaRecipes.filter((recipe) => recipe.data.tags.includes("青醬"));
const pestoMeatRecipes = pestoRecipes.filter((recipe) => recipe.data.tags.includes("雞肉料理"));
const pestoSeafoodRecipes = pestoRecipes.filter((recipe) => recipe.data.tags.includes("海鮮料理"));
const pestoBaseRecipes = pestoRecipes.filter(
  (recipe) => !recipe.data.tags.includes("雞肉料理") && !recipe.data.tags.includes("海鮮料理")
);
const otherPastaRecipes = pastaRecipes.filter((recipe) => !recipe.data.tags.includes("青醬"));
const commonIngredients = filterIngredientsWithRecipes(
  recipes,
  hub.commonIngredients
    .map((ingredientSlug) => getIngredientBySlug(ingredientSlug))
    .filter((ingredient): ingredient is NonNullable<typeof ingredient> => Boolean(ingredient))
);
const relatedScenarios = hub.relatedScenarios
  .map((scenarioSlug) => getScenarioBySlug(scenarioSlug))
  .filter((scenario): scenario is NonNullable<typeof scenario> => Boolean(scenario));
const collectionJsonLd = buildCollectionPageJsonLd(hub.seoTitle, hub.seoDescription, "/pasta/");
const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "首頁", path: "/" },
  { name: hub.name, path: "/pasta/" }
]);
const hubJsonLd = buildThingJsonLd(hub, "/pasta/");
const featuredEntry =
  pastaRecipes.find((recipe) => recipe.slug === "garlic-cream-shrimp-pasta") ?? pastaRecipes[0];
const featuredRecipe = featuredEntry
  ? {
      slug: featuredEntry.slug,
      title: featuredEntry.data.title,
      description: featuredEntry.data.description,
      coverImage: featuredEntry.data.coverImage,
      totalTime: featuredEntry.data.totalTime
    }
  : undefined;
---

<BaseLayout title={hub.seoTitle} description={hub.seoDescription} canonicalPath="/pasta">
  <JsonLd data={collectionJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />
  <JsonLd data={hubJsonLd} />
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">首頁</a>
        <span>/</span>
        <span>{hub.name}</span>
      </nav>

      <TopicHubIntro
        hub={{ name: hub.name, description: hub.description }}
        label="Pasta"
        heroCover="/images/recipes/garlic-cream-shrimp-pasta.webp"
        recipeCount={pastaRecipes.length}
        featured={featuredRecipe}
      />

      {pastaRecipes.length === 0 ? (
        <section class="section section-compact">
          <article class="card empty-panel">
            <div class="card-body">
              <h2>食譜整理中</h2>
              <p>義大利麵食譜會陸續上架，你也可以先從常見食材或料理情境找靈感。</p>
            </div>
          </article>
        </section>
      ) : (
        <>
          {pestoMeatRecipes.length > 0 && (
            <section class="hub-section">
              <div class="hub-section__head">
                <div>
                  <p class="eyebrow">青醬肉類</p>
                  <h2>雞肉搭配青醬的飽足主餐麵</h2>
                </div>
                <span>{pestoMeatRecipes.length} 道</span>
              </div>
              <div class="grid">
                {pestoMeatRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
              </div>
            </section>
          )}

          {pestoSeafoodRecipes.length > 0 && (
            <section class="hub-section">
              <div class="hub-section__head">
                <div>
                  <p class="eyebrow">青醬海鮮</p>
                  <h2>鮭魚、蝦仁與青醬的鮮甜組合</h2>
                </div>
                <span>{pestoSeafoodRecipes.length} 道</span>
              </div>
              <div class="grid">
                {pestoSeafoodRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
              </div>
            </section>
          )}

          {pestoBaseRecipes.length > 0 && (
            <section class="hub-section">
              <div class="hub-section__head">
                <div>
                  <p class="eyebrow">青醬基礎</p>
                  <h2>不需肉海鮮也能完成的青醬麵</h2>
                </div>
                <span>{pestoBaseRecipes.length} 道</span>
              </div>
              <div class="grid">
                {pestoBaseRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
              </div>
            </section>
          )}

          {otherPastaRecipes.length > 0 && (
            <section class="hub-section">
              <div class="hub-section__head">
                <div>
                  <p class="eyebrow">其他醬汁</p>
                  <h2>蒜香、番茄、白醬與奶香義大利麵</h2>
                </div>
                <span>{otherPastaRecipes.length} 道</span>
              </div>
              <div class="grid">
                {otherPastaRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
              </div>
            </section>
          )}
        </>
      )}

      <div class="ingredient-pills" aria-label="常用食材與情境">
        <p class="ingredient-pills__title">常用食材</p>
        {commonIngredients.map((ingredient) => (
          <a class="chip note" href={`/ingredients/${ingredient.slug}/`}>
            {ingredient.name}
          </a>
        ))}
        <p class="ingredient-pills__title">相關情境</p>
        {relatedScenarios.map((scenario) => (
          <a class="chip" href={`/scenarios/${scenario.slug}/`}>
            {scenario.name}
          </a>
        ))}
      </div>

      <div class="section-links">
        <a class="button" href="/ingredients/pasta/">義大利麵食材說明</a>
        <a class="button note" href="/ingredients/shrimp/">蝦仁食材說明</a>
        <a class="button note" href="/recipes">看全部食譜</a>
      </div>
    </div>
  </section>
</BaseLayout>
