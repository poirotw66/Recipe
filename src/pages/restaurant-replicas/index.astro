---
import { getCollection } from "astro:content";
import JsonLd from "../../components/JsonLd.astro";
import RecipeCard from "../../components/RecipeCard.astro";
import TopicHubIntro from "../../components/TopicHubIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import catalog from "../../data/restaurant-replica-catalog.json";
import { sortRecipesByPublishedDate } from "../../lib/recipes";
import { buildBreadcrumbJsonLd, buildCollectionPageJsonLd, buildThingJsonLd } from "../../lib/seo";
import {
  filterIngredientsWithRecipes,
  getIngredientBySlug,
  getRecipesByTopicHub,
  getTopicHubBySlug
} from "../../lib/taxonomy";

const hub = getTopicHubBySlug("restaurant-replicas");

if (!hub) {
  throw new Error("Restaurant replicas topic hub is not configured.");
}

const recipes = sortRecipesByPublishedDate(await getCollection("recipes"));
const replicaRecipes = getRecipesByTopicHub(recipes, hub.slug);
const commonIngredients = filterIngredientsWithRecipes(
  recipes,
  hub.commonIngredients
    .map((ingredientSlug) => getIngredientBySlug(ingredientSlug))
    .filter((ingredient): ingredient is NonNullable<typeof ingredient> => Boolean(ingredient))
);
const collectionJsonLd = buildCollectionPageJsonLd(
  hub.seoTitle,
  hub.seoDescription,
  "/restaurant-replicas/"
);
const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "首頁", path: "/" },
  { name: hub.name, path: "/restaurant-replicas/" }
]);
const hubJsonLd = buildThingJsonLd(hub, "/restaurant-replicas/");
const featuredEntry = replicaRecipes[0];
const featuredRecipe = featuredEntry
  ? {
      slug: featuredEntry.slug,
      title: featuredEntry.data.title,
      description: featuredEntry.data.description,
      coverImage: featuredEntry.data.coverImage,
      totalTime: featuredEntry.data.totalTime
    }
  : undefined;

const tierLabels: Record<string, string> = {
  "michelin-3": "米其林三星",
  "michelin-1": "米其林一星",
  "bib-gourmand": "必比登",
  classic: "經典名店"
};
---

<BaseLayout title={hub.seoTitle} description={hub.seoDescription} canonicalPath="/restaurant-replicas">
  <JsonLd data={collectionJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />
  <JsonLd data={hubJsonLd} />
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">首頁</a>
        <span>/</span>
        <span>{hub.name}</span>
      </nav>

      <TopicHubIntro
        hub={{ name: hub.name, description: hub.description }}
        label="Restaurant Replica"
        heroCover="/images/recipes/solo-three-cup-chicken-rice.webp"
        recipeCount={replicaRecipes.length}
        secondaryStat="盡力還原名店風味"
        featured={featuredRecipe}
      />

      {/* Brand Showcase Section */}
      <section class="hub-section">
        <div class="hub-section__head">
          <div>
            <p class="eyebrow">品牌店家專區</p>
            <h2>各名店還原度達成統計與完整菜單</h2>
          </div>
        </div>
        <div class="brand-showcases-grid">
          <article class="brand-card">
            <div>
              <div class="chip-row">
                <span class="chip success">已完成還原 {replicaRecipes.filter(r => r.slug.startsWith('sf-')).length}/70 道</span>
                <span class="chip note">達成率 100%</span>
              </div>
              <h3>貳樓 Second Floor Cafe</h3>
              <p class="brand-meta">全台連鎖早午餐品牌。包含熱門班尼迪克蛋、燉飯麵食與主廚甜點全系列還原。</p>
            </div>
            <a href="/restaurant-replicas/second-floor-cafe/" class="button small">進入店家專區</a>
          </article>
          
          <article class="brand-card">
            <div>
              <div class="chip-row">
                <span class="chip success">已完成還原 {replicaRecipes.filter(r => r.slug.startsWith('dh-')).length}/58 道</span>
                <span class="chip note">達成率 100%</span>
              </div>
              <h3>涓豆腐 Dubu House</h3>
              <p class="brand-meta">韓式第一連鎖品牌。包含經典豆腐煲系列、石鍋飯與蜂蜜蒜味炸雞全系列還原。</p>
            </div>
            <a href="/restaurant-replicas/dubu-house/" class="button small">進入店家專區</a>
          </article>
        </div>
      </section>

      <section class="hub-section">
        <div class="hub-section__head">
          <div>
            <p class="eyebrow">已上線還原食譜</p>
            <h2>照步驟還原，不刻意簡化</h2>
          </div>
          <span>{replicaRecipes.length} 道</span>
        </div>

        <div class="filter-tabs-wrapper" style="margin-bottom: var(--space-6);">
          <div class="filter-tabs" style="display: flex; gap: var(--space-2); flex-wrap: wrap;">
            <button class="button filter-tab active" data-filter="all">全部</button>
            <button class="button note filter-tab" data-filter="second-floor-cafe">貳樓 Cafe ({replicaRecipes.filter(r => r.slug.startsWith('sf-')).length})</button>
            <button class="button note filter-tab" data-filter="dubu-house">涓豆腐 ({replicaRecipes.filter(r => r.slug.startsWith('dh-')).length})</button>
          </div>
        </div>

        {replicaRecipes.length === 0 ? (
          <article class="card empty-panel">
            <div class="card-body">
              <h2>還原食譜撰寫中</h2>
              <p>
                第一批將從富錦樹樹子水蓮、欣葉菜脯蛋、明福鳳梨苦瓜雞湯與鼎泰豐苦瓜排骨湯開始。下方可預覽規劃中的餐廳與菜色。
              </p>
            </div>
          </article>
        ) : (
          <div class="grid recipes-grid-container">
            {replicaRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
          </div>
        )}
      </section>

      <style>
        .filter-tab {
          transition: background-color 0.2s, color 0.2s;
          cursor: pointer;
        }
        .filter-tab.active {
          background-color: var(--scallion) !important;
          color: #fff !important;
          border-color: var(--scallion-deep) !important;
        }
        .brand-showcases-grid {
          display: grid;
          grid-template-columns: 1fr;
          gap: var(--space-4);
          margin-bottom: var(--space-8);
        }
        @media (min-width: 720px) {
          .brand-showcases-grid {
            grid-template-columns: 1fr 1fr;
          }
        }
        .brand-card {
          border: 1px solid var(--bran-line);
          border-radius: var(--radius-md);
          background: var(--porcelain);
          padding: var(--space-6);
          box-shadow: var(--shadow-sm);
          display: flex;
          flex-direction: column;
          justify-content: space-between;
          transition: transform 0.2s, box-shadow 0.2s;
        }
        .brand-card:hover {
          transform: translateY(-2px);
          box-shadow: var(--shadow-md);
        }
        .brand-card h3 {
          margin-top: var(--space-2);
          margin-bottom: var(--space-2);
        }
        .brand-card .brand-meta {
          font-size: var(--small);
          color: var(--mushroom);
          margin-bottom: var(--space-4);
          line-height: 1.5;
        }
        .recipes-grid-container .recipe-card {
          transition: opacity 0.2s ease, transform 0.2s ease;
        }
      </style>

      <script>
        const tabs = document.querySelectorAll('.filter-tab');
        const cards = document.querySelectorAll('.recipes-grid-container .recipe-card');

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');

            const filterValue = tab.getAttribute('data-filter');

            cards.forEach(card => {
              const brand = card.getAttribute('data-brand');
              const el = card as HTMLElement;
              
              if (filterValue === 'all' || brand === filterValue) {
                el.style.display = 'block';
                setTimeout(() => {
                  el.style.opacity = '1';
                  el.style.transform = 'scale(1)';
                }, 10);
              } else {
                el.style.opacity = '0';
                el.style.transform = 'scale(0.95)';
                setTimeout(() => {
                  el.style.display = 'none';
                }, 200);
              }
            });
          });
        });
      </script>

      {
        catalog.categories.map((category) => (
          <section class="hub-section">
            <div class="hub-section__head">
              <div>
                <p class="eyebrow">{category.name}</p>
                <h2>{category.description}</h2>
              </div>
              <span>{category.restaurants.length} 家</span>
            </div>
            <div class="grid">
              {category.restaurants.map((restaurant) => (
                <article class="card card-body">
                  <div class="chip-row">
                    <span class="chip note">{restaurant.region}</span>
                    <span class="chip">{tierLabels[restaurant.tier] ?? restaurant.tier}</span>
                  </div>
                  <h3>{restaurant.name}</h3>
                  <p class="eyebrow">規劃還原菜色</p>
                  <ul>
                    {restaurant.signatureDishes.map((dish) => (
                      <li>
                        {dish.name}
                        {dish.status === "planned" && <span class="chip note"> 規劃中</span>}
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </section>
        ))
      }

      <div class="ingredient-pills" aria-label="常用食材">
        <p class="ingredient-pills__title">還原食譜常用食材</p>
        {commonIngredients.map((ingredient) => (
          <a class="chip note" href={`/ingredients/${ingredient.slug}/`}>
            {ingredient.name}
          </a>
        ))}
      </div>

      <div class="section-links">
        <a class="button" href="/recipes">看全部食譜</a>
        <a class="button note" href="/scenarios/">瀏覽料理情境</a>
      </div>
    </div>
  </section>
</BaseLayout>
