---
import { getCollection } from "astro:content";
import JsonLd from "../../components/JsonLd.astro";
import RecipeCard from "../../components/RecipeCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortRecipesByPublishedDate } from "../../lib/recipes";
import { buildBreadcrumbJsonLd, buildCollectionPageJsonLd, buildThingJsonLd } from "../../lib/seo";
import {
  getIngredientBySlug,
  getRecipesByTopicHub,
  getScenarioBySlug,
  getTopicHubBySlug
} from "../../lib/taxonomy";

const hub = getTopicHubBySlug("air-fryer");

if (!hub) {
  throw new Error("Air fryer topic hub is not configured.");
}

const recipes = sortRecipesByPublishedDate(await getCollection("recipes"));
const hubRecipes = getRecipesByTopicHub(recipes, hub.slug);
const commonIngredients = hub.commonIngredients
  .map((ingredientSlug) => getIngredientBySlug(ingredientSlug))
  .filter((ingredient): ingredient is NonNullable<typeof ingredient> => Boolean(ingredient));
const relatedScenarios = hub.relatedScenarios
  .map((scenarioSlug) => getScenarioBySlug(scenarioSlug))
  .filter((scenario): scenario is NonNullable<typeof scenario> => Boolean(scenario));
const collectionJsonLd = buildCollectionPageJsonLd(hub.seoTitle, hub.seoDescription, "/air-fryer/");
const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: "首頁", path: "/" },
  { name: hub.name, path: "/air-fryer/" }
]);
const hubJsonLd = buildThingJsonLd(hub, "/air-fryer/");
---

<BaseLayout title={hub.seoTitle} description={hub.seoDescription} canonicalPath="/air-fryer">
  <JsonLd data={collectionJsonLd} />
  <JsonLd data={breadcrumbJsonLd} />
  <JsonLd data={hubJsonLd} />
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">首頁</a>
        <span>/</span>
        <span>{hub.name}</span>
      </nav>

      <section class="recipe-hero">
        <div>
          <p class="eyebrow">Air Fryer</p>
          <h1 class="page-title">{hub.name}</h1>
          <p class="page-copy">{hub.description}</p>
          <div class="chip-row">
            {hub.tags.map((tag) => <span class="chip note">{tag}</span>)}
          </div>
        </div>
        <div class="card card-body taxonomy-summary">
          <p class="eyebrow">怎麼用這個專區</p>
          <p>{hub.seoDescription}</p>
        </div>
      </section>

      <section class="section section-compact">
        <p class="eyebrow">氣炸鍋食譜</p>
        <h2>少顧鍋的一人份主菜與配菜</h2>
        {hubRecipes.length === 0 ? (
          <article class="card empty-panel">
            <div class="card-body">
              <p>食譜整理中，你也可以先從「氣炸鍋料理」情境頁找靈感。</p>
            </div>
          </article>
        ) : (
          <div class="grid">
            {hubRecipes.map((recipe) => <RecipeCard recipe={recipe} />)}
          </div>
        )}
      </section>

      <section class="section section-compact">
        <div class="recipe-content-grid">
          <article class="card">
            <div class="card-body">
              <p class="eyebrow">常用食材</p>
              <div class="chip-row">
                {commonIngredients.map((ingredient) => (
                  <a class="chip note" href={`/ingredients/${ingredient.slug}/`}>
                    {ingredient.name}
                  </a>
                ))}
              </div>
            </div>
          </article>
          <article class="card">
            <div class="card-body">
              <p class="eyebrow">相關情境</p>
              <div class="chip-row">
                {relatedScenarios.map((scenario) => (
                  <a class="chip" href={`/scenarios/${scenario.slug}/`}>
                    {scenario.name}
                  </a>
                ))}
              </div>
            </div>
          </article>
        </div>
      </section>

      <div class="section-links">
        <a class="button" href="/scenarios/air-fryer-meals/">氣炸鍋料理情境</a>
        <a class="button note" href="/tools/fridge-recipe/">冰箱剩料工具</a>
        <a class="button note" href="/recipes">看全部食譜</a>
      </div>
    </div>
  </section>
</BaseLayout>
