---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import { adsenseClient, adsenseReady } from "../lib/site";
import { detectLocaleFromPath, localeToHtmlLang, type Locale } from "../lib/i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  type?: "website" | "article";
  locale?: Locale;
  /** Path without locale prefix, for hreflang alternates */
  alternatePath?: string;
  alternateLocales?: import("../lib/i18n").Locale[];
}

const {
  title,
  description,
  canonicalPath,
  ogImage,
  type,
  locale: localeProp,
  alternatePath,
  alternateLocales
} = Astro.props;
const locale = localeProp ?? detectLocaleFromPath(Astro.url.pathname);
const htmlLang = localeToHtmlLang[locale];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&family=Noto+Serif+TC:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <SeoHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      type={type}
      locale={locale}
      alternatePath={alternatePath}
      alternateLocales={alternateLocales}
    />
    {adsenseReady && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
      />
    )}
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
