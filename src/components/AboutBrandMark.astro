---
import { brandMarkImagePath } from "../lib/site";

interface Props {
  alt: string;
}

const { alt } = Astro.props;
---

<figure class="about-brand-mark">
  <img
    src={brandMarkImagePath}
    alt={alt}
    width="512"
    height="512"
    loading="lazy"
    decoding="async"
  />
</figure>
