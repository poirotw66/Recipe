---
import { localePath, t, type Locale } from "../lib/i18n";

interface FeaturedRecipe {
  slug: string;
  title: string;
  description: string;
  coverImage: string;
  totalTime: number;
}

interface Props {
  hub: {
    name: string;
    description: string;
  };
  label: string;
  heroCover: string;
  recipeCount: number;
  secondaryStat?: string;
  featured?: FeaturedRecipe;
  locale?: Locale;
}

const { hub, label, heroCover, recipeCount, secondaryStat, featured, locale = "zh-TW" } = Astro.props;
const defaultSecondaryStat = locale === "zh-TW" ? "一人份友善" : t(locale, "recipes.listDescription");
const featuredHref = featured ? localePath(locale, `/recipes/${featured.slug}`) : undefined;
---

<article class="hub-hero">
  <div
    class="hub-hero__bg"
    style={`background-image: linear-gradient(120deg, rgba(58, 50, 44, 0.62) 0%, rgba(58, 50, 44, 0.28) 45%, rgba(58, 50, 44, 0.08) 100%), url('${heroCover}')`}
    role="img"
    aria-label={`${hub.name}主視覺`}
  />
  <div class="hub-hero__content">
    <p class="eyebrow">{label}</p>
    <h1 class="page-title">{hub.name}</h1>
    <p class="page-copy">{hub.description}</p>
    <div class="hub-stats">
      <span class="hub-stat">{recipeCount} {t(locale, "taxonomy.topicHubCount")}</span>
      <span class="hub-stat">{secondaryStat ?? defaultSecondaryStat}</span>
    </div>
  </div>
</article>

{
  featured && featuredHref && (
    <a class="featured-card" href={featuredHref}>
      <div
        class="featured-card__img"
        style={`background-image: url('${featured.coverImage}')`}
        role="img"
        aria-label={featured.title}
      />
      <div>
        <span class="badge badge--outline">{locale === "zh-TW" ? "本週推薦" : t(locale, "recipe.relatedTitle")}</span>
        <h2>{featured.title}</h2>
        <p>{featured.description}</p>
        <span class="featured-card__cta">{t(locale, "recipe.backToList")} →</span>
      </div>
    </a>
  )
}
