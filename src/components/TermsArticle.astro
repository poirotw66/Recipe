---
import { contactEmail } from "../lib/site";
import { localePath, type Locale } from "../lib/i18n";
import { getTermsPage } from "../i18n/terms-page";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = getTermsPage(locale);
const contactPath = localePath(locale, "/contact");
const { updates } = content;
---

{
  content.sections.map((section) => (
    <section>
      <h2>{section.heading}</h2>
      {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </section>
  ))
}

<section>
  <h2>{content.updatesHeading}</h2>
  <p>
    {updates.beforeEmail}
    <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
    {updates.afterEmail}
    <a href={contactPath}>{updates.contactLinkLabel}</a>
    {updates.afterContactLink}
  </p>
</section>
