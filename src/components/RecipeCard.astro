---
import RecipeImage from "./RecipeImage.astro";
import type { RecipeEntry } from "../lib/recipes";
import { getRecipeMeta } from "../lib/recipes";

interface Props {
  recipe: RecipeEntry;
}

const { recipe } = Astro.props;
const meta = getRecipeMeta(recipe);
const equipmentText = recipe.data.equipment.join(",");
const searchableText = [
  recipe.data.title,
  recipe.data.description,
  recipe.data.category,
  ...recipe.data.scenarios,
  ...recipe.data.equipment,
  ...recipe.data.tags,
  ...recipe.data.ingredients.map((item) => item.name)
]
  .join(" ")
  .toLowerCase();
---

<article
  class="card recipe-card"
  data-recipe-search={searchableText}
  data-recipe-category={recipe.data.category}
  data-recipe-time={String(recipe.data.totalTime)}
  data-recipe-equipment={equipmentText}
>
  <a class="recipe-card__link" href={`/recipes/${recipe.slug}/`}>
    <RecipeImage src={recipe.data.coverImage} alt={`${recipe.data.title}成品圖`} />
    <div class="card-body">
      <h3>{recipe.data.title}</h3>
      <p>{recipe.data.description}</p>
      <div class="meta-row">
        {meta.map((item) => <span class="chip">{item}</span>)}
      </div>
      <div class="chip-row">
        {recipe.data.ingredients.slice(0, 3).map((item) => <span class="chip note">{item.name}</span>)}
        {recipe.data.scenarios.slice(0, 2).map((item) => <span class="chip">{item}</span>)}
      </div>
    </div>
  </a>
</article>
