---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "./Breadcrumb.astro";
import { localePath, t, type Locale } from "../lib/i18n";
import type { buildFridgeToolPayload } from "../lib/fridge-tool";

interface Props {
  locale: Locale;
  toolData: Awaited<ReturnType<typeof buildFridgeToolPayload>>;
}

const { locale, toolData } = Astro.props;
const canonical = localePath(locale, "/tools/fridge-recipe");
const recipesPath = localePath(locale, "/recipes");
const ingredientsPath = localePath(locale, "/ingredients");
const scenariosPath = localePath(locale, "/scenarios");
const quickLinks = toolData.quickIngredients.slice(0, 3);
---

<BaseLayout
  title={t(locale, "fridge.title")}
  description={t(locale, "fridge.description")}
  canonicalPath={canonical}
  locale={locale}
  alternatePath="/tools/fridge-recipe"
>
  <section class="section">
    <div class="container tool-layout">
      <div>
        <Breadcrumb
          items={[
            { name: t(locale, "nav.home"), href: localePath(locale, "/") },
            { name: t(locale, "fridge.title") }
          ]}
        />
        <p class="eyebrow">{t(locale, "fridge.eyebrow")}</p>
        <h1 class="page-title">{t(locale, "fridge.title")}</h1>
        <p class="page-copy">{t(locale, "fridge.intro")}</p>

        <form class="search-panel" data-fridge-form>
          <label class="field">
            <span class="eyebrow">{t(locale, "fridge.inputLabel")}</span>
            <textarea
              class="tool-input"
              name="ingredients"
              placeholder={t(locale, "fridge.placeholder")}
              data-fridge-input
            ></textarea>
          </label>
          <p class="form-error" data-fridge-error hidden>{t(locale, "fridge.errorEmpty")}</p>

          <div class="filter-group">
            <p class="filter-label">{t(locale, "fridge.prefLabel")}</p>
            <div class="chip-row" data-preference-group>
              {toolData.preferences.map((item) => (
                <button class="chip" type="button" data-preference={item.key} aria-pressed="false">
                  {item.label}
                </button>
              ))}
            </div>
          </div>

          <div class="filter-group">
            <p class="filter-label">{t(locale, "fridge.quickLabel")}</p>
            <div class="chip-row">
              {toolData.quickIngredients.map((item) => (
                <button class="chip note" type="button" data-quick-ingredient={item}>
                  {item}
                </button>
              ))}
            </div>
          </div>

          <div class="section-links">
            <button class="button primary" type="submit">{t(locale, "fridge.submit")}</button>
            <button class="button" type="button" data-fridge-clear hidden>{t(locale, "fridge.clear")}</button>
          </div>
        </form>
      </div>

      <div class="results-column" id="fridge-results" data-fridge-results-anchor>
        <section class="card empty-panel" data-fridge-empty>
          <div class="card-body">
            <p class="eyebrow">{t(locale, "fridge.emptyEyebrow")}</p>
            <h2>{t(locale, "fridge.emptyTitle")}</h2>
            <p>{t(locale, "fridge.emptyBody")}</p>
          </div>
        </section>

        <section class="card empty-panel" data-fridge-no-results hidden>
          <div class="card-body">
            <p class="eyebrow">{t(locale, "fridge.noResultsEyebrow")}</p>
            <h2>{t(locale, "fridge.noResultsTitle")}</h2>
            <p data-no-result-copy>{t(locale, "fridge.noResultsHint")}</p>
            <div class="chip-row" data-no-result-actions>
              {quickLinks.map((label) => (
                <a
                  class="chip note"
                  href={`${canonical}?ingredients=${encodeURIComponent(label)}#fridge-results`}
                >
                  {label}
                </a>
              ))}
              <a class="chip note" href={recipesPath}>{t(locale, "fridge.browseAll")}</a>
            </div>
          </div>
        </section>

        <p class="form-hint" data-fridge-low-hit hidden>{t(locale, "fridge.lowHit")}</p>

        <section class="section section-compact" data-fridge-results hidden>
          <p class="eyebrow">{t(locale, "fridge.resultsEyebrow")}</p>
          <div class="card result-summary">
            <div class="card-body">
              <h2>{t(locale, "fridge.resultsTitle")}</h2>
              <p data-result-summary-copy>{t(locale, "fridge.resultsSummaryDefault")}</p>
            </div>
          </div>
          <div class="grid" data-result-grid></div>
        </section>

        <section class="section section-compact">
          <p class="eyebrow">{t(locale, "fridge.exploreEyebrow")}</p>
          <div class="chip-row">
            <a class="chip note" href={recipesPath}>{t(locale, "fridge.exploreRecipes")}</a>
            <a class="chip note" href={ingredientsPath}>{t(locale, "fridge.exploreIngredients")}</a>
            <a class="chip note" href={scenariosPath}>{t(locale, "fridge.exploreScenarios")}</a>
          </div>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
<script is:inline id="fridge-tool-data" type="application/json" set:html={JSON.stringify(toolData)}></script>
<script is:inline src="/scripts/fridge-tool.js"></script>
