---
import { brandDisplayName, brandName, brandTagline, getSiteUrl, siteTitleSuffix } from "../lib/site";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  type?: "website" | "article";
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogImage = "/images/og-default.jpg",
  type = "website"
} = Astro.props;

const siteUrl = getSiteUrl();
const canonical = new URL(canonicalPath, siteUrl).toString();
const includesBrand = title.includes(brandName) || title.includes(brandTagline) || title.includes(brandDisplayName);
const fullTitle = includesBrand ? title : `${title}｜${siteTitleSuffix}`;
const ogImageUrl = new URL(ogImage, siteUrl).toString();
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content={siteTitleSuffix} />
<meta property="og:locale" content="zh_TW" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImageUrl} />
