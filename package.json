{
  "name": "recipe-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "node scripts/verify-site.mjs && node scripts/test-fridge-logic.mjs && node scripts/test-i18n.mjs && node scripts/verify-pilot-recipes.mjs",
    "lint": "node scripts/verify-site.mjs",
    "recipe-review:precheck": "node scripts/recipe-review-precheck.mjs --write",
    "recipe-review:full": "node scripts/recipe-review-full.mjs",
    "typecheck": "astro check",
    "brand-assets": "python3 scripts/process-brand-assets.py",
    "recipe-review:expand-steps": "node scripts/apply-step-detail-fixes.mjs",
    "recipe-i18n:sync-detail-steps": "node scripts/sync-localized-detail-steps.mjs",
    "recipe-i18n:translate-steps": "node scripts/batch-translate-flagged-steps.mjs",
    "recipe-i18n:translate-steps-one": "node scripts/gemini-translate-recipe-steps.mjs"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.6.0"
  }
}
